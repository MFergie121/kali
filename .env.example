# PostgreSQL connection string
# Local dev (Docker — run `npm run db:up` first): postgresql://postgres:postgres@localhost:5432/kali-afl
# Cloud SQL (via Cloud Run): postgresql://user:password@/kali?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kali-afl

# Generate with: openssl rand -hex 32
AUTH_SECRET=

# GitHub OAuth App — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Admin access — only this email can trigger scraping and manage API keys
ADMIN_EMAIL=

API_KEY_DEFAULT_LIMIT=

# Cron scrape authentication — use as: Authorization: Bearer <secret>
# Generate with: openssl rand -hex 32
SCRAPE_SECRET=
